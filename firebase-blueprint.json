{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A main service offered by the company",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "description", "image"]
    },
    "SpecializedService": {
      "title": "Specialized Service",
      "description": "A specialized transport service",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "image": { "type": "string" },
        "iconName": { "type": "string", "description": "Lucide icon name" },
        "iconImage": { "type": "string", "description": "Custom icon image URL" }
      },
      "required": ["title", "desc", "image"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site content and settings",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "notificationWhatsapp": { "type": "string" },
        "footerAbout": { "type": "string" },
        "footerAddress": { "type": "string" }
      }
    },
    "Trip": {
      "title": "Trip",
      "description": "A recorded trip for accounting purposes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "ID of the customer if logged in" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "passengers": { "type": "number" },
        "bags": { "type": "number" },
        "direction": { "type": "string" },
        "pickup": { "type": "string" },
        "dropoff": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "amount": { "type": "number" },
        "driverType": { "type": "string", "enum": ["In", "Out"] },
        "driverName": { "type": "string" },
        "driverCost": { "type": "number" },
        "profit": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Unpaid", "Pending"] },
        "status": { "type": "string", "enum": ["Requested", "Confirmed", "Completed", "Cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "date"]
    },
    "User": {
      "title": "User",
      "description": "A customer profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "FixedRoute": {
      "title": "Fixed Route",
      "description": "A predefined route with a fixed price",
      "type": "object",
      "properties": {
        "pickup": { "type": "string" },
        "dropoff": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["pickup", "dropoff", "price"]
    },
    "Driver": {
      "title": "Driver",
      "description": "A driver profile with registration and rating details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "carType": { "type": "string", "enum": ["Standard", "VIP", "Van"] },
        "plateNumber": { "type": "string" },
        "registrationStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminStatus": { "type": "string", "enum": ["active", "suspended"] },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "totalRating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "averageRating": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "phone", "carType", "plateNumber", "registrationStatus"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A user rating for a driver",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingId": { "type": "string" },
        "driverId": { "type": "string" },
        "customerId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "driverId", "customerId", "rating"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A real-time booking request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "pickupLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "dropoffLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "pickupAddress": { "type": "string" },
        "dropoffAddress": { "type": "string" },
        "carType": { "type": "string", "enum": ["Standard", "VIP", "Van"] },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["searching_driver", "driver_assigned", "on_the_way", "completed", "cancelled", "no_driver_found"] },
        "assignedDriverId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "pickupLocation", "dropoffLocation", "carType", "status"]
    },
    "DriverRequest": {
      "title": "Driver Request",
      "description": "A request sent to a specific driver",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "bookingId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "number" }
      },
      "required": ["driverId", "bookingId", "status", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Customer profiles collection"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Main services collection"
    },
    "/specialized_services/{specializedServiceId}": {
      "schema": "SpecializedService",
      "description": "Specialized services collection"
    },
    "/fixed_routes/{routeId}": {
      "schema": "FixedRoute",
      "description": "Predefined routes and prices"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Accounting trips collection"
    },
    "/drivers/{driverId}": {
      "schema": "Driver",
      "description": "Active drivers collection"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Real-time bookings collection"
    },
    "/driver_requests/{id}": {
      "schema": "DriverRequest",
      "description": "Individual requests to drivers"
    },
    "/ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Driver ratings collection"
    }
  }
}
