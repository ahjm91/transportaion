rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isValidTrip(data) {
      return data.customerName is string && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.amount is number &&
             data.bookingNumber is string &&
             data.createdAt is string;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ahjm91@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow write: if (isSignedIn() && request.auth.uid == userId && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isVerified', 'uid']))) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Site settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specialized Services
    match /specialized_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fixed Routes
    match /fixed_routes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Trips Collection - Secured (Server-only for creation ideally, but allowing update for admins)
    match /trips/{tripId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.get('userId', '') == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && isValidTrip(incoming())); 
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Analytics Events - Write only (App logs events, only admin can read)
    match /analytics_events/{eventId} {
      allow create: if true; // Allow anyone to log (including guests)
      allow read, update, delete: if isAdmin();
    }

    // Counters - Allow users to increment for booking numbers
    match /counters/{counterId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin Notifications
    match /admin_notifications/{notificationId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Drivers collection
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == driverId);
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAdmin() || 
                   (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                   (isAuthenticated() && resource.data.get('assignedDriverId', '') == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
                    (isAuthenticated() && request.auth.uid == resource.data.assignedDriverId) ||
                    (isAuthenticated() && request.auth.uid == resource.data.userId && resource.data.status == 'searching_driver');
      allow delete: if isAdmin();
    }

    // Driver Requests
    match /driver_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.driverId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.driverId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Reports - Professional Closure
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
