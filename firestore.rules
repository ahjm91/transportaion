rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "ahjm91@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDriver() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow write: if (isAuthenticated() && request.auth.uid == userId && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isVerified', 'uid']))) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // Site settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specialized Services
    match /specialized_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fixed Routes
    match /fixed_routes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Trips (Accounting)
    match /trips/{tripId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if true; 
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Counters for booking numbers
    match /counters/{counterId} {
      allow read, write: if true;
    }

    // Drivers collection
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == driverId);
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAdmin() || 
                   (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                   (isAuthenticated() && resource.data.get('assignedDriverId', '') == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
                    (isAuthenticated() && request.auth.uid == resource.data.assignedDriverId) ||
                    (isAuthenticated() && request.auth.uid == resource.data.userId && resource.data.status == 'searching_driver');
      allow delete: if isAdmin();
    }

    // Driver Requests
    match /driver_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.driverId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.driverId == request.auth.uid || isAdmin());
      allow read, write: if isAdmin();
    }
  }
}
