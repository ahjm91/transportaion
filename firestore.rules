rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // 1. GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      // Safe check for site settings admin list
      return isSignedIn() && 
             get(/databases/$(database)/documents/settings/site).data.adminEmails.hasAny([request.auth.token.email]); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ---------------------------------------------------------
    // 2. DEFAULT DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // 3. SETTINGS (MASTER CONFIG)
    // ---------------------------------------------------------
    match /settings/site {
      allow read: if true; // Publicly readable for site branding
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'heroTitle', 'heroSubtitle', 'heroDescription', 'phone', 'whatsapp', 
                        'primaryColor', 'secondaryColor', 'accentColor', 'showServicesSection', 
                        'showSpecializedSection', 'showHeroSection', 'showBookingSection',
                        'companyName', 'companyName_en', 'pricePerKm', 'baseFee', 'adminEmails',
                        'layoutDensity', 'sectionOrder'
                      ]);
      allow create, delete: if false; // Managed via server/admin
    }

    // ---------------------------------------------------------
    // 4. SERVICES & SPECIALIZED SERVICES (READ-ONLY FOR PUBLIC)
    // ---------------------------------------------------------
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /specialized_services/{specId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /fixed_routes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // 5. TRIPS (OWNER OR ADMIN)
    // ---------------------------------------------------------
    match /trips/{tripId} {
      function isValidTrip(data) {
        return data.customerName is string && data.customerName.size() <= 100 &&
               data.phone is string && data.phone.size() <= 20 &&
               data.date is string &&
               data.status in ['Requested', 'Confirmed', 'Completed', 'Cancelled'] &&
               (!('userId' in data) || data.userId is string);
      }

      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.phone == request.auth.token.email);
      allow create: if isValidTrip(incoming()) && 
                      (incoming().userId == request.auth.uid || !isSignedIn()); 
      allow update: if isAdmin() || 
                      (isSignedIn() && existing().userId == request.auth.uid && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes']) && 
                       incoming().status == 'Cancelled');
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 6. USERS
    // ---------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if (isOwner(userId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'photoURL', 'referralCode', 'driverApplicationStatus', 'driverApplicationData', 'availableRewards'])) || 
                       isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // 7. REAL-TIME BOOKINGS
    // ---------------------------------------------------------
    match /bookings/{bookingId} {
      allow read: if true; 
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if isAdmin() || (isOwner(driverId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'location', 'lastUpdated', 'isAcceptingOrders']));
    }
  }
}
