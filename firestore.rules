rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ahjm91@gmail.com" && request.auth.token.email_verified == true);
    }

    // Site settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specialized Services
    match /specialized_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
