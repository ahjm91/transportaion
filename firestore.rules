rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Bookings security
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      
      // Update logic:
      // 1. Admin/System updating driver assignment or status
      // 2. Assigned driver accepting the trip
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedDriverId', 'status', 'assignedAt', 'driverName', 'updatedAt', 'acceptedAt']) ||
        (resource.data.assignedDriverId == request.auth.uid && request.resource.data.status == 'accepted')
      );
    }

    // Drivers security
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

    // Users security
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
