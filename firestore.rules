rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny - currently allow for debugging
    match /{document=**} {
      allow read, write: if true;
    }

    // Bookings security
    match /bookings/{bookingId} {
      allow read, write: if true; 
    }

    // Drivers security
    match /drivers/{driverId} {
      allow read, write: if true;
    }

    // Users security
    match /users/{userId} {
      allow read, write: if true;
    }

    // Trips security
    match /trips/{tripId} {
      allow read, write: if true;
    }

    // Reports security
    match /reports/{reportId} {
      allow read, write: if true;
    }
  }
}
